# ============================================================
# .env.mailtrap.example - Cấu hình email với Mailtrap
# 
# HƯỚNG DẪN SỬ DỤNG:
# 1. Đăng ký tài khoản miễn phí tại https://mailtrap.io
# 2. Vào Email Testing → Inboxes → My Inbox → SMTP Settings
# 3. Copy username và password từ Mailtrap
# 4. Copy file này thành .env và điền thông tin
# ============================================================

APP_NAME="Quan ly Thiet bi Day hoc"
APP_ENV=local
APP_KEY=base64:YOUR_APP_KEY_HERE
APP_DEBUG=true
APP_TIMEZONE=Asia/Ho_Chi_Minh
APP_URL=http://localhost:8000

APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=vi_VN

# === Database ===
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=equipment_management
DB_USERNAME=root
DB_PASSWORD=

# === Session ===
SESSION_DRIVER=database
SESSION_LIFETIME=120

# === Cache ===
CACHE_STORE=database
CACHE_PREFIX=

# === Queue ===
QUEUE_CONNECTION=database

# ============================================================
# MAILTRAP CONFIGURATION
# Đăng ký free tại: https://mailtrap.io
# ============================================================
MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=YOUR_MAILTRAP_USERNAME
MAIL_PASSWORD=YOUR_MAILTRAP_PASSWORD
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@truong.edu.vn"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================================
# GMAIL CONFIGURATION (Alternative)
# Uncomment và điền thông tin nếu muốn dùng Gmail
# ============================================================
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your.email@gmail.com
# MAIL_PASSWORD=your_16_char_app_password
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS="your.email@gmail.com"
# MAIL_FROM_NAME="${APP_NAME}"

# === AI Services ===
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT=15

GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT=15

# === Logging ===
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# === Sanctum (API) ===
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000